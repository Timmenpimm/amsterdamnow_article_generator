# WordPress-koppeling (live modus). Zonder deze vars draait de tool in demo-modus.
WP_URL=https://www.amsterdamnow.com
WP_USER=
# Application password: WordPress-admin > Gebruikers > Profiel > Application Passwords
WP_APP_PASSWORD=

# Tavily levert de bronresearch vóór Claude schrijft. Maak een key in het Tavily-dashboard.
TAVILY_API_KEY=

# Claude (Anthropic) voor research-samenvatting, artikel en SEO. Maak een key in de Anthropic Console.
ANTHROPIC_API_KEY=
# Optioneel: overschrijf het standaardmodel.
ANTHROPIC_MODEL=claude-sonnet-4-20250514
